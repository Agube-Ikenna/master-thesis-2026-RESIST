(Decotabs_2019$temp * as.numeric(Decotabs_2019$duration))
# Chunk 35
Decotabs_2019$DSM_abs <- (((mean_Decot_trans - Decotabs_2019$afdm_end) /
mean_Decot_trans) * 100)
# Chunk 36
Decotabs_2019 <- Decotabs_2019[! is.na(Decotabs_2019$DSM) & Decotabs_2019$DSM > 0, ]
# 185 observations from 63 streams
